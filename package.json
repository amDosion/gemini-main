{
  "name": "gemini-flux-chat-local",
  "private": true,
  "version": "1.2.1",
  "type": "module",
  "scripts": {
    "dev": "node --no-deprecation ./node_modules/concurrently/dist/bin/concurrently.js \"npm run server\" \"vite\"",
    "server": "cd backend && PYTHONUNBUFFERED=1 .venv/bin/uvicorn app.main:app --reload --reload-dir app --host 0.0.0.0 --port 21574 --log-level info",
    "install:backend": "pip install -r backend/requirements.txt",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ci": "npm run test",
    "test:watch": "vitest",
    "test:backend": "sh -c 'cd backend && PY=.venv/bin/python; if [ -x \"$PY\" ]; then \"$PY\" -m pytest tests -q; else python3 -m pytest tests -q; fi'",
    "test:backend:cov": "sh -c 'cd backend && PY=.venv/bin/python; if [ -x \"$PY\" ]; then \"$PY\" -m pytest tests --cov=app --cov-report=term-missing; else python3 -m pytest tests --cov=app --cov-report=term-missing; fi'",
    "test:ui-result-panel": "vitest run frontend/components/multiagent/MultiAgentWorkflowEditorReactFlow.resultPanel.test.tsx --environment jsdom",
    "test:ui-mcp-settings": "vitest run frontend/components/modals/settings/McpTab.ui.test.tsx --environment jsdom",
    "e2e:agent": "node scripts/e2e/agent_workflow_e2e.mjs"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.8",
    "@google/genai": "^1.32.0",
    "@heroicons/react": "^2.1.1",
    "@iconify/react": "^6.0.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@skybridge/devtools": "^0.33.3",
    "@xyflow/react": "^12.10.0",
    "dompurify": "^3.3.1",
    "eventsource-parser": "^3.0.6",
    "form-data": "^4.0.5",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.561.0",
    "nodemon": "^3.1.14",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.11.0",
    "react-syntax-highlighter": "^16.1.0",
    "reactflow": "^11.11.4",
    "rehype-raw": "^7.0.0",
    "skybridge": "^0.33.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.2.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.2.2",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
