{
  "starter_key": "amazon_ads_full_funnel_optimizer_v1",
  "starter_version": 1,
  "name": "亚马逊广告全链路优化闭环",
  "description": "广告报表输入 → 数据质检 → 并行策略 → 交叉验证 → 可执行动作清单。",
  "category": "亚马逊运营",
  "workflow_type": "graph",
  "tags": [
    "amazon",
    "ads",
    "optimization",
    "validation",
    "parallel",
    "multi-agent"
  ],
  "config": {
    "schemaVersion": 2,
    "nodes": [
      {
