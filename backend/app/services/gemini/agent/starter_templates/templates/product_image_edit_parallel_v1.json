          "y": 240
        },
        "data": {
          "type": "start",
          "label": "图生图输入",
          "description": "输入编辑目标和输出用途",
          "icon": "🚀",
          "iconColor": "bg-blue-500"
        }
      },
      {
        "id": "input-image-img-edit-parallel",
        "type": "input_image",
        "position": {
          "x": 300,
          "y": 240
        },
        "data": {
          "type": "input_image",
          "label": "参考图输入",
          "description": "上传原图或填写 imageUrl（图生图必填）",
          "icon": "🖼️",
          "iconColor": "bg-lime-500",
          "startImageUrl": ""
        }
      },
      {
        "id": "input-text-img-edit-parallel",
        "type": "input_text",
        "position": {
          "x": 520,
          "y": 240
        },
        "data": {
          "type": "input_text",
          "label": "编辑目标",
          "description": "例如：主图白底 + 场景图 + 卖点特写",
          "icon": "📝",
          "iconColor": "bg-emerald-500",
          "startTask": ""
        }
      },
      {
        "id": "agent-edit-plan",
        "type": "agent",
        "position": {
          "x": 760,
          "y": 240
        },
        "data": {
          "type": "agent",
          "label": "编辑规划",
          "description": "生成三路图生图编辑提示词",
          "icon": "🧠",
          "iconColor": "bg-violet-500",
          "agentName": "图片编辑优化师",
          "inputMapping": "编辑目标：{{input-text-img-edit-parallel.output.text}}\\n参考图地址：{{input-image-img-edit-parallel.output.imageUrl}}\\n\\n请输出三路图生图提示词：\\n- 主图编辑提示词\\n- 场景图编辑提示词\\n- 卖点图编辑提示词",
          "instructions": "请根据参考图与编辑目标，生成可直接执行的图生图提示词，确保不改变核心产品形态。"
        }
      },
      {
        "id": "parallel-img-edit",
        "type": "parallel",
        "position": {
          "x": 1000,
          "y": 240
        },
        "data": {
          "type": "parallel",
          "label": "并行编辑",
          "description": "并行生成主图/场景图/卖点图",
          "icon": "⚡",
          "iconColor": "bg-yellow-500",
          "joinMode": "wait_all"
        }
      },
      {
        "id": "tool-main-edit",
        "type": "agent",
        "position": {
          "x": 1240,
          "y": 100
