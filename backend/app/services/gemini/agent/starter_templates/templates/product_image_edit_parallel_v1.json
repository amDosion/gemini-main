{
  "starter_key": "product_image_edit_parallel_v1",
  "starter_version": 9,
  "name": "产品图片图生图并行工作流",
  "description": "纯图生图流程：参考图输入 + 编辑规划 + 并行多 Agent 编辑 + 质检汇总。",
  "category": "图像工作流",
  "workflow_type": "graph",
  "tags": [
    "image",
    "image-to-image",
    "parallel",
    "multi-agent"
  ],
