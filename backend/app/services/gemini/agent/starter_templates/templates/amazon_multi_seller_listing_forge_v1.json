        "id": "e-ml-9",
        "source": "agent-positioning-multi-listing",
        "target": "merge-multi-listing"
      },
      {
        "id": "e-ml-10",
        "source": "agent-segment-multi-listing",
        "target": "merge-multi-listing"
      },
      {
        "id": "e-ml-11",
        "source": "merge-multi-listing",
        "target": "agent-listing-draft-multi-listing"
      },
      {
        "id": "e-ml-12",
        "source": "agent-listing-draft-multi-listing",
