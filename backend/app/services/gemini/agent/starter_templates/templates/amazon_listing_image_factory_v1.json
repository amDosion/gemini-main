        "data": {
          "type": "agent",
          "label": "交付审阅",
          "description": "输出最终交付清单与迭代建议",
          "icon": "✅",
          "iconColor": "bg-emerald-500",
          "agentName": "图片编辑优化师",
          "inputMapping": "四类素材摘要：{{merge-listing-image-factory.output.text}}",
          "instructions": "请做交付审阅（不要再索要输入）：\n1. 每类推荐图\n2. 合规风险标注\n3. 二次迭代提示词\n4. 最终交付清单。"
        }
      },
      {
        "id": "end-listing-image-factory",
        "type": "end",
        "position": {
          "x": 1760,
          "y": 240
        },
        "data": {
          "type": "end",
          "label": "Listing 图片交付",
          "description": "输出可落地的图片素材方案",
          "icon": "🏁",
          "iconColor": "bg-green-500"
        }
      }
