        "data": {
          "type": "parallel",
          "label": "并行生成",
          "description": "并行生成四类 Listing 素材",
          "icon": "⚡",
          "iconColor": "bg-yellow-500",
          "joinMode": "wait_all"
        }
      },
      {
        "id": "agent-main-listing-image",
        "type": "agent",
        "position": {
          "x": 1040,
          "y": 60
