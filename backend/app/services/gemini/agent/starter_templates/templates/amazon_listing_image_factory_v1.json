        "type": "start",
        "position": {
          "x": 80,
          "y": 240
        },
        "data": {
          "type": "start",
          "label": "Listing 图片目标",
          "description": "输入产品信息、目标人群、卖点方向",
          "icon": "🚀",
          "iconColor": "bg-blue-500"
        }
      },
      {
        "id": "input-text-listing-image-factory",
        "type": "input_text",
        "position": {
          "x": 320,
          "y": 240
        },
        "data": {
          "type": "input_text",
          "label": "产品与卖点输入",
          "description": "例如：核心卖点、禁用元素、品牌风格",
          "icon": "📝",
          "iconColor": "bg-emerald-500",
          "startTask": ""
        }
      },
      {
        "id": "agent-copy-brief-listing-image",
        "type": "agent",
        "position": {
          "x": 560,
          "y": 240
        },
