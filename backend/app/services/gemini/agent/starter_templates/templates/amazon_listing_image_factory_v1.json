          "type": "agent",
          "label": "主图生成",
          "description": "生成 Amazon 白底主图",
          "icon": "🖼️",
          "iconColor": "bg-pink-500",
          "agentName": "产品图片设计师",
          "agentTaskType": "image-gen",
          "agentAspectRatio": "1:1",
          "agentNumberOfImages": 1,
          "inputMapping": "{{agent-copy-brief-listing-image.output.text}}\\n\\n请执行主图生成：白底、无文字、无水印、主体完整。",
          "instructions": "先优化提示词再生成图片，确保主图合规。"
        }
      },
      {
        "id": "agent-scene-listing-image",
        "type": "agent",
        "position": {
          "x": 1040,
          "y": 180
