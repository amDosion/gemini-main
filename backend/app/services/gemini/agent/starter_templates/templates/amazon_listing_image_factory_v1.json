{
  "starter_key": "amazon_listing_image_factory_v1",
  "starter_version": 2,
  "name": "Amazon Listing 卖点图工厂",
  "description": "卖点提炼 + 并行文生图（主图/场景/细节/对比）+ 交付审阅。",
  "category": "图像工作流",
  "workflow_type": "graph",
  "tags": [
    "amazon",
    "listing",
    "image",
    "image-gen",
    "parallel",
    "multi-agent"
