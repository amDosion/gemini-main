        "data": {
          "type": "agent",
          "label": "细节图生成",
          "description": "生成材质与工艺细节图",
          "icon": "🔍",
          "iconColor": "bg-violet-500",
          "agentName": "产品图片设计师",
          "agentTaskType": "image-gen",
          "agentAspectRatio": "1:1",
          "agentNumberOfImages": 1,
          "inputMapping": "{{agent-copy-brief-listing-image.output.text}}\\n\\n请执行细节图生成：突出材质、结构、做工。",
          "instructions": "聚焦卖点细节，画面干净。"
        }
      },
      {
        "id": "agent-compare-listing-image",
        "type": "agent",
        "position": {
          "x": 1040,
          "y": 420
        },
        "data": {
          "type": "agent",
          "label": "对比图生成",
          "description": "生成差异化对比卖点图",
          "icon": "📌",
          "iconColor": "bg-teal-500",
          "agentName": "产品图片设计师",
          "agentTaskType": "image-gen",
          "agentAspectRatio": "4:3",
          "agentNumberOfImages": 1,
          "inputMapping": "{{agent-copy-brief-listing-image.output.text}}\\n\\n请执行对比图生成：体现核心差异化优势，突出购买理由。",
          "instructions": "对比要清晰，不要加入违规元素。"
        }
      },
      {
        "id": "merge-listing-image-factory",
        "type": "merge",
        "position": {
          "x": 1280,
          "y": 240
        },
        "data": {
          "type": "merge",
          "label": "素材汇总",
          "description": "汇总四类素材输出",
          "icon": "🔗",
          "iconColor": "bg-gray-500",
          "mergeStrategy": "append"
        }
      },
      {
        "id": "agent-qa-listing-image",
        "type": "agent",
        "position": {
          "x": 1520,
          "y": 240
