{
  "starter_key": "amazon_search_term_harvest_v1",
  "starter_version": 1,
  "name": "Amazon 搜索词挖掘闭环",
  "description": "报表输入 + 并行否定词/加投词/意图聚类 + 执行清单输出。",
  "category": "亚马逊运营",
  "workflow_type": "graph",
  "tags": [
    "amazon",
    "ads",
    "keyword",
    "negative",
    "scale",
    "parallel",
    "multi-agent"
  ],
  "config": {
    "schemaVersion": 2,
    "nodes": [
      {
        "id": "start-search-term-harvest",
        "type": "start",
        "position": {
          "x": 80,
          "y": 240
        },
        "data": {
          "type": "start",
          "label": "搜索词分析目标",
          "description": "输入本轮广告优化目标与约束",
          "icon": "🚀",
          "iconColor": "bg-blue-500"
        }
      },
      {
        "id": "input-file-search-term-harvest",
        "type": "input_file",
        "position": {
          "x": 320,
          "y": 240
        },
        "data": {
          "type": "input_file",
          "label": "搜索词报表",
          "description": "上传 Search Term / Placement / Campaign 报表",
          "icon": "📎",
          "iconColor": "bg-cyan-500",
          "startFileUrl": ""
        }
      },
      {
        "id": "input-text-search-term-harvest",
        "type": "input_text",
        "position": {
          "x": 560,
          "y": 240
        },
        "data": {
          "type": "input_text",
          "label": "业务约束输入",
          "description": "例如：目标 ACoS 28%，优先控亏后放量",
          "icon": "📝",
          "iconColor": "bg-emerald-500",
          "startTask": ""
        }
      },
      {
        "id": "agent-schema-search-term-harvest",
        "type": "agent",
        "position": {
          "x": 800,
          "y": 240
        },
        "data": {
          "type": "agent",
          "label": "报表结构解析",
          "description": "解析关键字段并输出结构化摘要",
          "icon": "🧩",
          "iconColor": "bg-indigo-500",
          "agentName": "数据报表分析师",
          "agentTaskType": "data-analysis",
          "agentFileUrl": "{{input-file-search-term-harvest.output.fileUrl}}",
          "inputMapping": "业务约束：{{input-text-search-term-harvest.output.text}}\\n报表文件：{{input-file-search-term-harvest.output.fileUrl}}",
          "instructions": "请输出结构化摘要：\n1. 字段映射（impressions/clicks/spend/sales/orders/acos）\n2. 异常字段与缺失值\n3. 可直接用于否定词与加投词筛选的样例。"
        }
      },
      {
        "id": "parallel-search-term-harvest",
        "type": "parallel",
        "position": {
          "x": 1040,
          "y": 240
        },
        "data": {
          "type": "parallel",
          "label": "并行挖掘",
          "description": "并行执行否定词、加投词与意图聚类",
          "icon": "⚡",
          "iconColor": "bg-yellow-500",
          "joinMode": "wait_all"
        }
      },
      {
        "id": "agent-negative-search-term-harvest",
        "type": "agent",
        "position": {
          "x": 1280,
          "y": 80
        },
        "data": {
          "type": "agent",
          "label": "否定词挖掘",
          "description": "识别高花费低转化词",
          "icon": "⛔",
          "iconColor": "bg-red-500",
          "agentName": "亚马逊广告分析师",
          "inputMapping": "结构化摘要：{{agent-schema-search-term-harvest.output.text}}\\n业务约束：{{input-text-search-term-harvest.output.text}}",
          "instructions": "请输出否定词建议：\n1. 立即否定（P0）\n2. 观察否定（P1）\n3. 推荐匹配类型（exact/phrase）\n4. 触发依据。"
        }
      },
      {
        "id": "agent-scale-search-term-harvest",
        "type": "agent",
        "position": {
          "x": 1280,
          "y": 240
        },
        "data": {
          "type": "agent",
          "label": "加投词挖掘",
          "description": "识别高转化可扩量词",
          "icon": "📈",
          "iconColor": "bg-emerald-500",
          "agentName": "亚马逊广告分析师",
          "inputMapping": "结构化摘要：{{agent-schema-search-term-harvest.output.text}}\\n业务约束：{{input-text-search-term-harvest.output.text}}",
          "instructions": "请输出加投词建议：\n1. 高效词清单\n2. 建议竞价区间\n3. 建议预算提升幅度\n4. 观察指标阈值。"
        }
      },
      {
        "id": "agent-intent-search-term-harvest",
        "type": "agent",
        "position": {
          "x": 1280,
          "y": 400
        },
        "data": {
          "type": "agent",
          "label": "意图聚类与分组",
          "description": "按购买意图拆分词包与投放动作",
          "icon": "🧠",
          "iconColor": "bg-violet-500",
          "agentName": "关键词研究专家",
          "inputMapping": "结构化摘要：{{agent-schema-search-term-harvest.output.text}}",
          "instructions": "请输出关键词意图聚类：\n1. 强购买意图词包\n2. 信息探索词包\n3. 竞品拦截词包\n4. 各词包的匹配方式与投放策略。"
        }
      },
      {
        "id": "merge-search-term-harvest",
        "type": "merge",
        "position": {
          "x": 1520,
          "y": 240
        },
        "data": {
          "type": "merge",
          "label": "结果汇总",
          "description": "合并三路挖掘结果",
          "icon": "🔗",
          "iconColor": "bg-gray-500",
          "mergeStrategy": "append"
        }
      },
      {
        "id": "agent-action-search-term-harvest",
        "type": "agent",
        "position": {
          "x": 1760,
          "y": 240
        },
        "data": {
          "type": "agent",
          "label": "执行清单输出",
          "description": "生成今日/本周动作清单",
          "icon": "✅",
          "iconColor": "bg-indigo-500",
          "agentName": "运营策略顾问",
          "inputMapping": "三路汇总：{{merge-search-term-harvest.output.text}}",
          "instructions": "请输出执行清单：\n1. 今日执行（P0）\n2. 本周执行（P1）\n3. 预期影响指标\n4. 回滚阈值与复盘节点。"
        }
      },
      {
        "id": "end-search-term-harvest",
        "type": "end",
        "position": {
          "x": 2000,
          "y": 240
        },
        "data": {
          "type": "end",
          "label": "搜索词动作看板",
          "description": "输出否定词与加投词闭环方案",
          "icon": "🏁",
          "iconColor": "bg-green-500"
        }
      }
    ],
    "edges": [
      {
        "id": "e-sth-1",
        "source": "start-search-term-harvest",
        "target": "input-file-search-term-harvest"
      },
      {
        "id": "e-sth-2",
        "source": "input-file-search-term-harvest",
        "target": "input-text-search-term-harvest"
      },
      {
        "id": "e-sth-3",
        "source": "input-text-search-term-harvest",
        "target": "agent-schema-search-term-harvest"
      },
      {
        "id": "e-sth-4",
        "source": "agent-schema-search-term-harvest",
        "target": "parallel-search-term-harvest"
      },
      {
        "id": "e-sth-5",
        "source": "parallel-search-term-harvest",
        "target": "agent-negative-search-term-harvest"
      },
      {
        "id": "e-sth-6",
        "source": "parallel-search-term-harvest",
        "target": "agent-scale-search-term-harvest"
      },
      {
        "id": "e-sth-7",
        "source": "parallel-search-term-harvest",
        "target": "agent-intent-search-term-harvest"
      },
      {
        "id": "e-sth-8",
        "source": "agent-negative-search-term-harvest",
        "target": "merge-search-term-harvest"
      },
      {
        "id": "e-sth-9",
        "source": "agent-scale-search-term-harvest",
        "target": "merge-search-term-harvest"
      },
      {
        "id": "e-sth-10",
        "source": "agent-intent-search-term-harvest",
        "target": "merge-search-term-harvest"
      },
      {
        "id": "e-sth-11",
        "source": "merge-search-term-harvest",
        "target": "agent-action-search-term-harvest"
      },
      {
        "id": "e-sth-12",
        "source": "agent-action-search-term-harvest",
        "target": "end-search-term-harvest"
      }
    ]
  }
}
