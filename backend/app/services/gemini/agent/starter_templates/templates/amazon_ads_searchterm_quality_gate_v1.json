      },
      {
        "id": "e-asq-5",
        "source": "parallel-ads-quality-gate",
        "target": "agent-negative-ads-quality-gate"
      },
      {
        "id": "e-asq-6",
        "source": "parallel-ads-quality-gate",
        "target": "agent-scale-ads-quality-gate"
      },
      {
        "id": "e-asq-7",
        "source": "parallel-ads-quality-gate",
        "target": "agent-anomaly-ads-quality-gate"
      },
      {
        "id": "e-asq-8",
        "source": "agent-negative-ads-quality-gate",
        "target": "merge-ads-quality-gate"
      },
      {
        "id": "e-asq-9",
        "source": "agent-scale-ads-quality-gate",
        "target": "merge-ads-quality-gate"
      },
      {
        "id": "e-asq-10",
        "source": "agent-anomaly-ads-quality-gate",
        "target": "merge-ads-quality-gate"
      },
      {
        "id": "e-asq-11",
        "source": "merge-ads-quality-gate",
        "target": "agent-quality-gate-ads-quality-gate"
      },
      {
        "id": "e-asq-12",
        "source": "agent-quality-gate-ads-quality-gate",
        "target": "agent-action-ads-quality-gate"
      },
      {
        "id": "e-asq-13",
