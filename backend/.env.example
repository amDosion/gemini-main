# =============================================================================
# 数据库配置
# =============================================================================
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/dbname

# =============================================================================
# 服务器配置
# =============================================================================
HOST=0.0.0.0
PORT=21574

# =============================================================================
# Redis 配置
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your-redis-password

# =============================================================================
# Worker 运行模式
# =============================================================================
# - "embedded": 内嵌在主进程中（推荐，使用现有 Redis 队列系统）
# - "separate_process": 独立子进程（原有 Worker 池）
# - "disabled": 禁用 Worker（需要外部 Worker 服务）
WORKER_MODE=embedded

# 禁用 Python 输出缓冲（确保日志立即显示）
PYTHONUNBUFFERED=1

# 日志级别
LOG_LEVEL=INFO

# =============================================================================
# 认证配置
# =============================================================================
ALLOW_REGISTRATION=false
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# JWT 密钥（生产环境请使用强随机密钥）
# 可通过 python -c "import secrets; print(secrets.token_urlsafe(64))" 生成
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# 数据加密密钥（用于加密敏感数据如 Service Account JSON）
# 可通过 python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())" 生成
ENCRYPTION_KEY=your-encryption-key-change-in-production

# =============================================================================
# Google AI 配置（选择其一）
# =============================================================================

# 方式1: Gemini API（推荐，简单易用）
# GEMINI_API_KEY=your-gemini-api-key

# 方式2: Vertex AI（企业级，需要 GCP 项目）
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# =============================================================================
# 阿里云通义千问配置（可选）
# =============================================================================
# DASHSCOPE_API_KEY=your-dashscope-api-key

# =============================================================================
# OpenAI 配置（可选）
# =============================================================================
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# =============================================================================
# Qwen-Image-Layered 图层分解服务（可选，外部独立部署）
# =============================================================================
# QWEN_LAYERED_ENDPOINT=http://localhost:9527/decompose
# QWEN_LAYERED_API_KEY=your-layered-service-api-key
# QWEN_LAYERED_TIMEOUT_SEC=180
