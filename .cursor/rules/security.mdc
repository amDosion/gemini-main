## 四、用户数据隔离

### 4.1 所有查询加 user_id 过滤

```python
# ✅ 正确：加 user_id 过滤
def get_user_sessions(db: Session, user_id: str) -> List[ChatSession]:
    return db.query(ChatSession).filter(
        ChatSession.user_id == user_id  # 必须！
    ).all()

# ❌ 错误：不加 user_id
def get_session_by_id(db: Session, session_id: str) -> ChatSession:
    return db.query(ChatSession).filter(
        ChatSession.id == session_id
        # 缺少 user_id 过滤！可能访问他人数据
    ).first()

# ✅ 正确：加 user_id
def get_session_by_id(db: Session, session_id: str, user_id: str) -> ChatSession:
    return db.query(ChatSession).filter(
        ChatSession.id == session_id,
        ChatSession.user_id == user_id
    ).first()
```

### 4.2 依赖注入确保 user_id 可用

```python
# 路由层统一注入
@router.get("/sessions")
async def get_sessions(
    user_id: str = Depends(require_current_user),  # 必须
    db: Session = Depends(get_db)
):
    return get_user_sessions(db, user_id)

@router.get("/sessions/{session_id}")
async def get_session(
    session_id: str,
    user_id: str = Depends(require_current_user),  # 必须
    db: Session = Depends(get_db)
):
    session = get_session_by_id(db, session_id, user_id)
    if not session:
        raise HTTPException(status_code=404, detail="Session not found")
    return session
```

### 4.3 权限验证

```python
def verify_resource_ownership(
    db: Session,
    resource_id: str,
    user_id: str,
    model_class: Type
) -> bool:
    """验证资源所有权"""
    resource = db.query(model_class).filter(
        model_class.id == resource_id,
        model_class.user_id == user_id
    ).first()
    return resource is not None

# 使用
@router.delete("/sessions/{session_id}")
async def delete_session(
    session_id: str,
    user_id: str = Depends(require_current_user),
    db: Session = Depends(get_db)
):
    if not verify_resource_ownership(db, session_id, user_id, ChatSession):
        raise HTTPException(status_code=404, detail="Session not found")

    # 安全删除
    db.query(ChatSession).filter(
        ChatSession.id == session_id,
        ChatSession.user_id == user_id
    ).delete()
    db.commit()
```

