## 三、API Key 安全

### 3.1 加密存储

```python
# backend/app/core/encryption.py

from cryptography.fernet import Fernet
import os
from pathlib import Path

def get_encryption_key() -> bytes:
    """
    获取加密密钥

    优先级：
    1. 环境变量 ENCRYPTION_KEY
    2. 文件 credentials/.encryption_key
    3. 自动生成（开发环境）
    """
    # 环境变量
    key = os.environ.get("ENCRYPTION_KEY")
    if key:
        return key.encode() if isinstance(key, str) else key

    # 文件
    key_file = Path("credentials/.encryption_key")
    if key_file.exists():
        return key_file.read_bytes().strip()

    # 生成新密钥（仅开发环境）
    if os.environ.get("ENVIRONMENT") == "development":
        key = Fernet.generate_key()
        key_file.parent.mkdir(parents=True, exist_ok=True)
        key_file.write_bytes(key)
        key_file.chmod(0o600)  # 仅所有者可读写
        return key

    raise ValueError("ENCRYPTION_KEY not configured")

def encrypt_data(data: str) -> str:
    """加密数据"""
    if not data:
        return data

    key = get_encryption_key()
    f = Fernet(key)
    encrypted = f.encrypt(data.encode())
    return f"encrypted:{encrypted.decode()}"

def decrypt_data(encrypted: str) -> str:
    """解密数据"""
    if not encrypted:
        return encrypted

    # 移除前缀
    if encrypted.startswith("encrypted:"):
        encrypted = encrypted[10:]

    key = get_encryption_key()
    f = Fernet(key)
    return f.decrypt(encrypted.encode()).decode()

def is_encrypted(data: str) -> bool:
    """检查是否已加密"""
    if not data:
        return False
    return data.startswith("encrypted:") or data.startswith("gAAAAA")
```

### 3.2 统一解密入口

```python
# backend/app/core/credential_manager.py

async def get_provider_credentials(
    provider: str,
    db: Session,
    user_id: str,
    request_api_key: Optional[str] = None
) -> Tuple[str, Optional[str]]:
    """
    获取提供商凭证

    关键点：
    1. 所有 API Key 解密在此统一完成
    2. 服务层接收的是已解密的明文
    3. ProviderFactory 不负责解密
    """
    # 请求参数优先（用于测试）
    if request_api_key and request_api_key.strip():
        return request_api_key, None

    # 从数据库获取
    profile = db.query(ConfigProfile).filter(
        ConfigProfile.user_id == user_id,
        ConfigProfile.provider_id == provider
    ).first()

    if profile and profile.api_key:
        # 统一解密
        api_key = _decrypt_api_key(profile.api_key)
        return api_key, profile.base_url

    raise HTTPException(
        status_code=401,
        detail=f"API Key not found for provider: {provider}"
    )

def _decrypt_api_key(api_key: str) -> str:
    """解密 API Key（内部函数）"""
    if not api_key:
        return api_key

    if not is_encrypted(api_key):
        return api_key  # 明文直接返回

    try:
        return decrypt_data(api_key)
    except Exception as e:
        logger.error(f"[Credential] Failed to decrypt API key: {e}")
        raise HTTPException(
            status_code=500,
            detail="Failed to decrypt API key"
        )
```

