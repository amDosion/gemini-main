## 四、数据库操作规范

### 4.1 模型定义

```python
# models/db_models.py

from sqlalchemy import Column, String, DateTime, ForeignKey, Text, Boolean, Integer
from sqlalchemy.orm import relationship
from datetime import datetime
import uuid

class Base:
    """模型基类"""
    id = Column(String(36), primary_key=True, default=lambda: str(uuid.uuid4()))
    created_at = Column(DateTime, default=datetime.utcnow)
    updated_at = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow)

class User(Base):
    __tablename__ = "users"

    email = Column(String(255), unique=True, nullable=False, index=True)
    password_hash = Column(String(255), nullable=False)

    # 关系
    config_profiles = relationship("ConfigProfile", back_populates="user")
    sessions = relationship("ChatSession", back_populates="user")

class ConfigProfile(Base):
    __tablename__ = "config_profiles"

    user_id = Column(String(36), ForeignKey("users.id"), nullable=False, index=True)
    name = Column(String(100), nullable=False)
    provider_id = Column(String(50), nullable=False, index=True)
    api_key = Column(Text)  # 加密存储
    base_url = Column(String(500))

    # 复合索引
    __table_args__ = (
        Index("idx_user_provider", "user_id", "provider_id"),
    )

    user = relationship("User", back_populates="config_profiles")

    def to_dict(self) -> dict:
        """转换为前端格式（camelCase，隐藏敏感信息）"""
        return {
            "id": self.id,
            "name": self.name,
            "providerId": self.provider_id,
            "hasApiKey": bool(self.api_key),  # 不返回实际 key
            "baseUrl": self.base_url,
            "createdAt": self.created_at.isoformat() if self.created_at else None
        }
```

### 4.2 查询规范

```python
# 所有查询必须加 user_id 过滤
def get_user_sessions(db: Session, user_id: str) -> List[ChatSession]:
    """获取用户的所有会话"""
    return db.query(ChatSession).filter(
        ChatSession.user_id == user_id
    ).order_by(
        ChatSession.created_at.desc()
    ).all()

# 使用 select 进行复杂查询
from sqlalchemy import select

stmt = select(ConfigProfile).where(
    ConfigProfile.user_id == user_id,
    ConfigProfile.provider_id == provider
)
result = db.execute(stmt).scalars().first()

# 分页查询
def get_messages_paginated(
    db: Session,
    session_id: str,
    user_id: str,
    offset: int = 0,
    limit: int = 50
) -> List[Message]:
    return db.query(Message).filter(
        Message.session_id == session_id,
        Message.user_id == user_id
    ).order_by(
        Message.created_at.asc()
    ).offset(offset).limit(limit).all()
```

### 4.3 事务处理

```python
# 使用上下文管理器
from contextlib import contextmanager

@contextmanager
def transaction(db: Session):
    """事务上下文管理器"""
    try:
        yield db
        db.commit()
    except Exception as e:
        db.rollback()
        raise

# 使用
with transaction(db):
    profile = ConfigProfile(...)
    db.add(profile)
    settings = UserSettings(...)
    db.add(settings)
    # 自动提交或回滚
```

