## 五、凭证管理规范

### 5.1 统一解密

```python
# core/credential_manager.py

async def get_provider_credentials(
    provider: str,
    db: Session,
    user_id: str,
    request_api_key: Optional[str] = None
) -> Tuple[str, Optional[str]]:
    """
    获取提供商凭证（API Key 和 Base URL）

    优先级：
    1. 请求参数（用于测试/覆盖）
    2. 数据库配置（自动解密）

    返回：
    - api_key: 已解密的明文
    - base_url: 可选的自定义 URL
    """
    # 1. 优先使用请求参数
    if request_api_key and request_api_key.strip():
        return request_api_key, None

    # 2. 从数据库获取
    settings = db.query(UserSettings).filter(
        UserSettings.user_id == user_id
    ).first()

    if settings and settings.active_profile_id:
        profile = db.query(ConfigProfile).filter(
            ConfigProfile.id == settings.active_profile_id,
            ConfigProfile.provider_id == provider
        ).first()

        if profile and profile.api_key:
            # 自动解密
            api_key = _decrypt_api_key(profile.api_key)
            return api_key, profile.base_url

    # 3. 回退查找
    any_profile = db.query(ConfigProfile).filter(
        ConfigProfile.user_id == user_id,
        ConfigProfile.provider_id == provider
    ).first()

    if any_profile and any_profile.api_key:
        api_key = _decrypt_api_key(any_profile.api_key)
        return api_key, any_profile.base_url

    raise HTTPException(
        status_code=401,
        detail=f"API Key not found for provider: {provider}"
    )


def _decrypt_api_key(api_key: str) -> str:
    """解密 API Key（如果已加密）"""
    if not api_key:
        return api_key

    if not is_encrypted(api_key):
        return api_key  # 明文直接返回

    return decrypt_data(api_key)
```

### 5.2 加密存储

```python
# core/encryption.py

from cryptography.fernet import Fernet
import os

def get_encryption_key() -> bytes:
    """获取加密密钥"""
    key = os.environ.get("ENCRYPTION_KEY")
    if key:
        return key.encode()

    # 从文件读取
    key_file = Path("credentials/.encryption_key")
    if key_file.exists():
        return key_file.read_bytes()

    raise ValueError("ENCRYPTION_KEY not configured")

def encrypt_data(data: str) -> str:
    """加密数据"""
    key = get_encryption_key()
    f = Fernet(key)
    return f"encrypted:{f.encrypt(data.encode()).decode()}"

def decrypt_data(encrypted: str) -> str:
    """解密数据"""
    key = get_encryption_key()
    f = Fernet(key)

    # 移除前缀
    if encrypted.startswith("encrypted:"):
        encrypted = encrypted[10:]

    return f.decrypt(encrypted.encode()).decode()

def is_encrypted(data: str) -> bool:
    """检查是否已加密"""
    return data.startswith("encrypted:") or data.startswith("gAAAAA")
```

