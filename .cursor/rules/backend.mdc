## 六、日志规范

### 6.1 日志配置

```python
# core/logger.py

import logging
import sys

LOG_PREFIXES = {
    'search': '[SEARCH]',
    'success': '[OK]',
    'error': '[ERROR]',
    'warning': '[WARN]',
    'info': '[INFO]',
    'debug': '[DEBUG]',
    'api': '[API]',
    'db': '[DB]',
    'cache': '[CACHE]',
}

def get_logger(name: str) -> logging.Logger:
    """获取配置好的日志器"""
    logger = logging.getLogger(name)

    if not logger.handlers:
        handler = FlushingStreamHandler(sys.stdout)
        handler.setFormatter(logging.Formatter(
            '%(asctime)s - %(name)s - %(levelname)s - %(message)s'
        ))
        logger.addHandler(handler)
        logger.setLevel(logging.INFO)

    return logger

class FlushingStreamHandler(logging.StreamHandler):
    """每条日志后自动刷新"""
    def emit(self, record):
        super().emit(record)
        self.flush()
```

### 6.2 日志使用

```python
logger = get_logger(__name__)

# 正常操作
logger.info(f"{LOG_PREFIXES['success']} User {user_id} logged in")

# 错误
logger.error(f"{LOG_PREFIXES['error']} Failed to create service: {e}")

# 警告
logger.warning(f"{LOG_PREFIXES['warning']} Deprecated API called")

# API 调用
logger.info(f"{LOG_PREFIXES['api']} Calling {provider} API with model {model}")

# 数据库操作
logger.debug(f"{LOG_PREFIXES['db']} Query: {query}")
