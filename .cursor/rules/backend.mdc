## 七、测试规范

### 7.1 单元测试

```python
# tests/test_auth_service.py

import pytest
from unittest.mock import Mock, patch
from app.services.common.auth_service import AuthService

class TestAuthService:
    @pytest.fixture
    def mock_db(self):
        return Mock()

    @pytest.fixture
    def auth_service(self, mock_db):
        return AuthService(mock_db)

    def test_verify_password_success(self, auth_service):
        # 准备
        hashed = auth_service.hash_password("test123")

        # 执行
        result = auth_service.verify_password("test123", hashed)

        # 断言
        assert result is True

    def test_verify_password_failure(self, auth_service):
        hashed = auth_service.hash_password("test123")
        result = auth_service.verify_password("wrong", hashed)
        assert result is False
```

