## 二、路由开发规范

### 2.1 认证使用依赖注入

```python
# ✅ 正确方式：使用依赖注入
from ..core.dependencies import require_current_user, get_current_user_optional
from ..core.database import get_db

@router.post("/{provider}/chat")
async def chat_with_provider(
    provider: str,
    request: ChatRequest,
    user_id: str = Depends(require_current_user),  # 强制认证
    db: Session = Depends(get_db)
):
    # user_id 已自动注入
    api_key, base_url = await get_provider_credentials(
        provider=provider,
        db=db,
        user_id=user_id
    )
    # 使用已解密的 api_key
    service = ProviderFactory.create(
        provider=provider,
        api_key=api_key,
        user_id=user_id,
        db=db
    )
    return await service.chat(...)

# 可选认证
@router.get("/public")
async def public_endpoint(
    user_id: Optional[str] = Depends(get_current_user_optional)
):
    if user_id:
        # 已登录用户逻辑
        pass
    else:
        # 未登录用户逻辑
        pass

# ❌ 错误方式：手动调用
@router.post("/endpoint")
async def endpoint(request: Request):
    from ..core.user_context import require_user_id
    user_id = require_user_id(request)  # 不推荐！
```

### 2.2 请求/响应模型

```python
from pydantic import BaseModel, Field
from typing import Optional, List

class ChatRequest(BaseModel):
    """聊天请求模型"""
    modelId: str = Field(..., description="模型 ID")
    messages: List[MessageItem] = Field(default=[], description="历史消息")
    message: str = Field(..., description="当前消息")
    options: ChatOptions = Field(default_factory=ChatOptions)
    stream: bool = Field(default=True, description="是否流式响应")

    class Config:
        # 允许额外字段（向前兼容）
        extra = "allow"

class ChatResponse(BaseModel):
    """聊天响应模型"""
    content: str
    attachments: Optional[List[Attachment]] = None
    groundingMetadata: Optional[dict] = None

    class Config:
        # 自动转换 snake_case 到 camelCase
        populate_by_name = True
```

### 2.3 流式响应

```python
from fastapi.responses import StreamingResponse
import json

@router.post("/{provider}/chat")
async def chat_with_provider(...):
    if request.stream:
        return StreamingResponse(
            stream_chat_response(service, request),
            media_type="text/event-stream",
            headers={
                "Cache-Control": "no-cache",
                "Connection": "keep-alive",
                "X-Accel-Buffering": "no"  # Nginx 禁用缓冲
            }
        )
    else:
        result = await service.chat(...)
        return result

async def stream_chat_response(service, request):
    """流式响应生成器"""
    try:
        async for chunk in service.chat_stream(...):
            yield f"data: {json.dumps(chunk)}\n\n"
        yield "data: [DONE]\n\n"
    except Exception as e:
        yield f"data: {json.dumps({'error': str(e)})}\n\n"
```

