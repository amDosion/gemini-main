## 三、服务层规范

### 3.1 提供商工厂模式

```python
# services/common/provider_factory.py

class ProviderFactory:
    """
    提供商服务工厂

    特点：
    - 配置驱动注册
    - 服务实例缓存
    - 统一的创建接口
    """
    _providers: Dict[str, Type[BaseProviderService]] = {}
    _client_cache: Dict[str, BaseProviderService] = {}

    @classmethod
    def register(cls, provider_id: str, service_class: Type[BaseProviderService]):
        """注册提供商服务类"""
        cls._providers[provider_id] = service_class

    @classmethod
    def create(
        cls,
        provider: str,
        api_key: str,           # 已解密的明文
        api_url: Optional[str] = None,
        user_id: Optional[str] = None,
        db: Optional[Session] = None
    ) -> BaseProviderService:
        """创建或获取缓存的服务实例"""
        cache_key = f"{provider}:{api_key[:8]}..."  # 避免完整 key 暴露

        if cache_key not in cls._client_cache:
            service_class = cls._providers.get(provider)
            if not service_class:
                raise ValueError(f"Provider '{provider}' not registered")

            cls._client_cache[cache_key] = service_class(
                api_key=api_key,
                api_url=api_url,
                user_id=user_id,
                db=db
            )

        return cls._client_cache[cache_key]
```

### 3.2 基础服务类

```python
# services/common/base_provider.py

from abc import ABC, abstractmethod
from typing import AsyncGenerator, List, Dict, Any

class BaseProviderService(ABC):
    """提供商服务基类"""

    def __init__(
        self,
        api_key: str,
        api_url: Optional[str] = None,
        user_id: Optional[str] = None,
        db: Optional[Session] = None
    ):
        self.api_key = api_key
        self.api_url = api_url
        self.user_id = user_id
        self.db = db

    @abstractmethod
    async def chat(
        self,
        messages: List[Dict[str, Any]],
        model: str,
        options: Dict[str, Any]
    ) -> Dict[str, Any]:
        """非流式聊天"""
        pass

    @abstractmethod
    async def chat_stream(
        self,
        messages: List[Dict[str, Any]],
        model: str,
        options: Dict[str, Any]
    ) -> AsyncGenerator[Dict[str, Any], None]:
        """流式聊天"""
        pass

    @abstractmethod
    async def generate_image(
        self,
        prompt: str,
        model: str,
        **kwargs
    ) -> Dict[str, Any]:
        """图片生成"""
        pass
```

### 3.3 错误处理

```python
# services/common/errors.py

from dataclasses import dataclass, field
from typing import Dict, Any, Optional, Literal

@dataclass
class ErrorContext:
    """错误上下文信息"""
    provider_id: str
    client_type: Literal['primary', 'secondary', 'single']
    operation: str
    request_id: str
    user_id: Optional[str] = None
    model: Optional[str] = None
    execution_time_ms: Optional[float] = None
    additional_context: Dict[str, Any] = field(default_factory=dict)

class ProviderError(Exception):
    """提供商错误基类"""
    def __init__(
        self,
        message: str,
        code: str,
        context: Optional[ErrorContext] = None,
        recoverable: bool = False
    ):
        super().__init__(message)
        self.message = message
        self.code = code
        self.context = context
        self.recoverable = recoverable

    def to_dict(self) -> Dict[str, Any]:
        return {
            "code": self.code,
            "message": self.message,
            "recoverable": self.recoverable,
            "context": asdict(self.context) if self.context else None
        }

class APIKeyError(ProviderError):
    """API Key 错误"""
    def __init__(self, message: str = "Invalid or expired API key"):
        super().__init__(message, "API_KEY_ERROR", recoverable=False)

class RateLimitError(ProviderError):
    """速率限制错误"""
    def __init__(self, message: str = "Rate limit exceeded"):
        super().__init__(message, "RATE_LIMIT_ERROR", recoverable=True)

class TimeoutError(ProviderError):
    """超时错误"""
    def __init__(self, message: str = "Request timed out"):
        super().__init__(message, "TIMEOUT_ERROR", recoverable=True)
```

