## 四、流式响应

### 4.1 Server-Sent Events (SSE)

```http
POST /api/modes/google/chat
Content-Type: application/json

Response:
Content-Type: text/event-stream
Cache-Control: no-cache
Connection: keep-alive

data: {"type": "text", "content": "Hello"}

data: {"type": "text", "content": ", how"}

data: {"type": "text", "content": " are you?"}

data: {"type": "thinking", "content": "Let me think..."}

data: {"type": "grounding", "metadata": {...}}

data: [DONE]
```

### 4.2 流式数据类型

```typescript
// 文本块
{ "type": "text", "content": "..." }

// 思考过程
{ "type": "thinking", "content": "..." }

// 搜索结果
{ "type": "search", "results": [...] }

// Grounding 元数据
{ "type": "grounding", "metadata": {...} }

// 工具调用
{ "type": "tool_call", "name": "...", "arguments": {...} }

// 工具结果
{ "type": "tool_result", "content": "..." }

// 图片
{ "type": "image", "url": "...", "mimeType": "..." }

// 错误
{ "type": "error", "code": "...", "message": "..." }

// 结束
[DONE]
```

### 4.3 前端处理

```typescript
async function* streamChat(request: ChatRequest): AsyncGenerator<StreamChunk> {
  const response = await fetch('/api/modes/google/chat', {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${token}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify(request)
  })

  const reader = response.body!.getReader()
  const decoder = new TextDecoder()
  let buffer = ''

  while (true) {
    const { done, value } = await reader.read()
    if (done) break

    buffer += decoder.decode(value, { stream: true })
    const lines = buffer.split('\n')
    buffer = lines.pop() || ''

    for (const line of lines) {
      if (line.startsWith('data: ')) {
        const data = line.slice(6)
        if (data === '[DONE]') {
          return
        }
        yield JSON.parse(data)
      }
    }
  }
}

// 使用
for await (const chunk of streamChat(request)) {
  switch (chunk.type) {
    case 'text':
      appendText(chunk.content)
      break
    case 'thinking':
      showThinking(chunk.content)
      break
    case 'grounding':
      setGrounding(chunk.metadata)
      break
  }
}
```

