## 五、API 调用规范

### 5.1 API 客户端

```typescript
// services/apiClient.ts

class ApiClient {
  private baseUrl = '/api'

  private async request<T>(
    url: string,
    options: RequestInit = {}
  ): Promise<T> {
    const token = localStorage.getItem('access_token')

    const response = await fetch(`${this.baseUrl}${url}`, {
      ...options,
      headers: {
        'Authorization': token ? `Bearer ${token}` : '',
        'Content-Type': 'application/json',
        ...options.headers
      }
    })

    // 自动刷新 token
    if (response.status === 401) {
      const refreshed = await this.refreshToken()
      if (refreshed) {
        return this.request<T>(url, options)
      }
      // 刷新失败，跳转登录
      window.location.href = '/login'
      throw new Error('Session expired')
    }

    if (!response.ok) {
      const error = await response.json()
      throw new ApiError(response.status, error)
    }

    return response.json()
  }

  async get<T>(url: string): Promise<T> {
    return this.request<T>(url)
  }

  async post<T>(url: string, data: any): Promise<T> {
    return this.request<T>(url, {
      method: 'POST',
      body: JSON.stringify(data)
    })
  }

  async put<T>(url: string, data: any): Promise<T> {
    return this.request<T>(url, {
      method: 'PUT',
      body: JSON.stringify(data)
    })
  }

  async delete<T>(url: string): Promise<T> {
    return this.request<T>(url, {
      method: 'DELETE'
    })
  }

  private async refreshToken(): Promise<boolean> {
    try {
      const refreshToken = localStorage.getItem('refresh_token')
      if (!refreshToken) return false

      const response = await fetch(`${this.baseUrl}/auth/refresh`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ refreshToken })
      })

      if (response.ok) {
        const { accessToken } = await response.json()
        localStorage.setItem('access_token', accessToken)
        return true
      }

      return false
    } catch {
      return false
    }
  }
}

export const apiClient = new ApiClient()
```

### 5.2 数据库 API

```typescript
// services/db.ts

import { apiClient } from './apiClient'
import type { ChatSession, ConfigProfile, Persona } from '../types/types'

class ApiDB {
  // Sessions
  async getSessions(): Promise<ChatSession[]> {
    return apiClient.get<ChatSession[]>('/sessions')
  }

  async createSession(title: string, mode: string): Promise<ChatSession> {
    return apiClient.post<ChatSession>('/sessions', { title, mode })
  }

  async updateSession(id: string, data: Partial<ChatSession>): Promise<void> {
    return apiClient.put<void>(`/sessions/${id}`, data)
  }

  async deleteSession(id: string): Promise<void> {
    return apiClient.delete<void>(`/sessions/${id}`)
  }

  // Profiles
  async getProfiles(): Promise<ConfigProfile[]> {
    return apiClient.get<ConfigProfile[]>('/profiles')
  }

  async saveProfile(profile: Partial<ConfigProfile>): Promise<ConfigProfile> {
    if (profile.id) {
      return apiClient.put<ConfigProfile>(`/profiles/${profile.id}`, profile)
    }
    return apiClient.post<ConfigProfile>('/profiles', profile)
  }

  // Personas
  async getPersonas(): Promise<Persona[]> {
    return apiClient.get<Persona[]>('/personas')
  }
}

export const apiDB = new ApiDB()
```

### 5.3 错误处理

```typescript
// utils/errorHandler.ts

interface ErrorHandlerResult {
  code: string
  message: string
  suggestions: string[]
}

export function handleError(error: any): ErrorHandlerResult {
  // 网络错误
  if (error instanceof TypeError && error.message === 'Failed to fetch') {
    return {
      code: 'NETWORK_ERROR',
      message: '网络连接失败',
      suggestions: [
        '检查网络连接',
        '检查后端服务是否运行',
        '检查防火墙设置'
      ]
    }
  }

  // API 错误
  if (error instanceof ApiError) {
    switch (error.status) {
      case 401:
        return {
          code: 'UNAUTHORIZED',
          message: '身份验证失败',
          suggestions: ['请重新登录']
        }
      case 429:
        return {
          code: 'RATE_LIMITED',
          message: 'API 调用过于频繁',
          suggestions: ['请稍后重试']
        }
      default:
        return {
          code: error.data?.code || 'API_ERROR',
          message: error.data?.message || '请求失败',
          suggestions: []
        }
    }
  }

  // 未知错误
  return {
    code: 'UNKNOWN',
    message: error.message || '未知错误',
    suggestions: []
  }
}

// 使用
try {
  await apiClient.post('/chat', data)
} catch (error) {
  const result = handleError(error)
  showToast(result.message, 'error')
  console.error(`[API] ${result.code}: ${result.message}`)
}
```

