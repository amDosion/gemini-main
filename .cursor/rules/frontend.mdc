## 三、Hook 开发规范

### 3.1 自定义 Hook 模板

```typescript
// hooks/useChat.ts

import { useState, useCallback, useRef, useEffect } from 'react'
import type { Message, Attachment, LoadingState } from '../types/types'

interface UseChatOptions {
  sessionId: string | null
  onSessionUpdate?: (id: string, messages: Message[]) => void
}

interface UseChatReturn {
  messages: Message[]
  setMessages: React.Dispatch<React.SetStateAction<Message[]>>
  loadingState: LoadingState
  sendMessage: (text: string, attachments: Attachment[]) => Promise<void>
  stopGeneration: () => void
}

export const useChat = (options: UseChatOptions): UseChatReturn => {
  const { sessionId, onSessionUpdate } = options

  // 状态
  const [messages, setMessages] = useState<Message[]>([])
  const [loadingState, setLoadingState] = useState<LoadingState>('idle')

  // Ref（不触发重渲染的值）
  const abortControllerRef = useRef<AbortController | null>(null)

  // 发送消息
  const sendMessage = useCallback(async (
    text: string,
    attachments: Attachment[]
  ) => {
    if (!sessionId || loadingState === 'loading') return

    setLoadingState('loading')
    abortControllerRef.current = new AbortController()

    try {
      // 添加用户消息
      const userMessage: Message = {
        id: crypto.randomUUID(),
        role: 'user',
        content: text,
        attachments,
        timestamp: Date.now()
      }
      setMessages(prev => [...prev, userMessage])

      // 调用 API...
      const response = await llmService.sendMessage(text, {
        signal: abortControllerRef.current.signal
      })

      // 添加模型响应
      const modelMessage: Message = {
        id: crypto.randomUUID(),
        role: 'model',
        content: response.content,
        timestamp: Date.now()
      }
      setMessages(prev => [...prev, modelMessage])

    } catch (error) {
      if (error.name !== 'AbortError') {
        console.error('[useChat] Send failed:', error)
      }
    } finally {
      setLoadingState('idle')
      abortControllerRef.current = null
    }
  }, [sessionId, loadingState])

  // 停止生成
  const stopGeneration = useCallback(() => {
    abortControllerRef.current?.abort()
    setLoadingState('idle')
  }, [])

  // 同步到父组件
  useEffect(() => {
    if (sessionId && onSessionUpdate) {
      onSessionUpdate(sessionId, messages)
    }
  }, [sessionId, messages, onSessionUpdate])

  return {
    messages,
    setMessages,
    loadingState,
    sendMessage,
    stopGeneration
  }
}
```

### 3.2 策略模式 Hook

```typescript
// hooks/handlers/StrategyRegistry.ts

import type { AppMode } from '../../types/types'

interface BaseHandler {
  process(context: ExecutionContext): Promise<void>
}

class StrategyRegistry {
  private strategies: Map<AppMode, BaseHandler> = new Map()

  register(mode: AppMode, handler: BaseHandler): void {
    this.strategies.set(mode, handler)
  }

  get(mode: AppMode): BaseHandler {
    const handler = this.strategies.get(mode)
    if (!handler) {
      // 回退到默认处理器
      return this.strategies.get('chat')!
    }
    return handler
  }

  has(mode: AppMode): boolean {
    return this.strategies.has(mode)
  }
}

// 使用
const registry = new StrategyRegistry()
registry.register('chat', new ChatHandler())
registry.register('image-gen', new ImageGenHandler())
registry.register('video-gen', new VideoGenHandler())

// 在 Hook 中
const handler = registry.get(currentMode)
await handler.process(context)
```

### 3.3 Hook 规则

```typescript
// ✅ 正确：Hook 在组件顶层调用
const MyComponent: React.FC = () => {
  const [value, setValue] = useState('')
  const { data } = useQuery()

  // ...
}

// ❌ 错误：条件调用 Hook
const MyComponent: React.FC = ({ condition }) => {
  if (condition) {
    const [value, setValue] = useState('')  // 错误！
  }
}

// ✅ 正确：条件逻辑在 Hook 内部
const useConditionalData = (condition: boolean) => {
  const [data, setData] = useState(null)

  useEffect(() => {
    if (condition) {
      fetchData().then(setData)
    }
  }, [condition])

  return data
}
```

