## 二、组件开发规范

### 2.1 函数组件模板

```typescript
import React, { useState, useCallback, useMemo } from 'react'
import type { Message, Attachment } from '../types/types'

// Props 接口定义
interface MessageItemProps {
  message: Message
  onImageClick?: (url: string) => void
  loading?: boolean
  className?: string
}

// 函数组件
const MessageItem: React.FC<MessageItemProps> = ({
  message,
  onImageClick,
  loading = false,
  className = ''
}) => {
  // 1. Hooks（按顺序：useState, useCallback, useMemo, useEffect）
  const [expanded, setExpanded] = useState(false)

  // 2. 事件处理（使用 useCallback 稳定引用）
  const handleClick = useCallback(() => {
    if (onImageClick && message.attachments?.[0]?.url) {
      onImageClick(message.attachments[0].url)
    }
  }, [onImageClick, message.attachments])

  const handleToggle = useCallback(() => {
    setExpanded(prev => !prev)
  }, [])

  // 3. 计算值（使用 useMemo 缓存）
  const formattedContent = useMemo(() => {
    return message.content.trim()
  }, [message.content])

  // 4. 条件渲染
  if (loading) {
    return <LoadingSpinner />
  }

  // 5. 主渲染
  return (
    <div className={`message-item ${className}`}>
      <div className="message-content" onClick={handleClick}>
        {formattedContent}
      </div>
      {message.attachments && message.attachments.length > 0 && (
        <AttachmentGrid
          attachments={message.attachments}
          expanded={expanded}
          onToggle={handleToggle}
        />
      )}
    </div>
  )
}

// 使用 memo 优化重渲染
export default React.memo(MessageItem)
```

