## 四、前端开发规范

### 4.1 组件设计规范

**函数组件 + TypeScript：**

```typescript
interface MessageItemProps {
  message: Message
  onImageClick?: (url: string) => void
  loading?: boolean
}

const MessageItem: React.FC<MessageItemProps> = ({
  message,
  onImageClick,
  loading = false
}) => {
  const [expanded, setExpanded] = useState(false)

  const handleClick = useCallback(() => {
    if (onImageClick && message.attachments?.[0]?.url) {
      onImageClick(message.attachments[0].url)
    }
  }, [onImageClick, message.attachments])

  return (
    <div className="message-item">
      {/* 组件内容 */}
    </div>
  )
}

export default MessageItem
```

**组件分层：**
```
components/
├── auth/          # 认证相关组件
├── chat/          # 聊天界面组件
├── common/        # 通用组件（Loading, Error, Toast）
├── layout/        # 布局组件
├── message/       # 消息相关组件
├── modals/        # 模态框组件
├── views/         # 视图组件（页面级）
└── workspaces/    # 工作区组件
```

### 4.2 Hook 设计规范

**自定义 Hook 模式：**

```typescript
// hooks/useChat.ts
export const useChat = (
  currentSessionId: string | null,
  updateSessionMessages: (id: string, msgs: Message[]) => void
) => {
  const [messages, setMessages] = useState<Message[]>([])
  const [loadingState, setLoadingState] = useState<LoadingState>('idle')

  const sendMessage = useCallback(async (text: string, attachments: Attachment[]) => {
    // 发送消息逻辑
  }, [/* 依赖项 */])

  const stopGeneration = useCallback(() => {
    // 停止生成逻辑
  }, [])

  return {
    messages,
    setMessages,
    loadingState,
    sendMessage,
    stopGeneration
  }
}
```

**策略模式处理不同模式：**

```typescript
// hooks/handlers/StrategyRegistry.ts
class StrategyRegistry {
  private strategies: Map<AppMode, BaseHandler> = new Map()

  register(mode: AppMode, handler: BaseHandler) {
    this.strategies.set(mode, handler)
  }

  get(mode: AppMode): BaseHandler {
    return this.strategies.get(mode) || this.strategies.get('chat')!
  }
}

// 使用
const registry = new StrategyRegistry()
registry.register('chat', new ChatHandler())
registry.register('image-gen', new ImageGenHandler())
```

### 4.3 状态管理规范

**优先使用 React 内置状态管理：**

```typescript
// 组件内状态
const [isLoading, setIsLoading] = useState(false)

// 跨组件共享状态（Context）
const ToastContext = createContext<ToastContextType | null>(null)

export const ToastProvider: React.FC<PropsWithChildren> = ({ children }) => {
  const [toasts, setToasts] = useState<Toast[]>([])

  const showToast = useCallback((message: string, type: ToastType) => {
    // 添加 toast
  }, [])

  return (
    <ToastContext.Provider value={{ toasts, showToast }}>
      {children}
    </ToastContext.Provider>
  )
}

export const useToast = () => {
  const context = useContext(ToastContext)
  if (!context) throw new Error('useToast must be used within ToastProvider')
  return context
}
```

### 4.4 API 调用规范

```typescript
// services/apiClient.ts
class ApiClient {
  private async request<T>(url: string, options: RequestOptions): Promise<T> {
    const token = localStorage.getItem('access_token')

    const response = await fetch(url, {
      ...options,
      headers: {
        'Authorization': `Bearer ${token}`,
        'Content-Type': 'application/json',
        ...options.headers
      }
    })

    if (response.status === 401) {
      // 自动刷新 token 并重试
      await this.refreshToken()
      return this.request<T>(url, options)
    }

    if (!response.ok) {
      throw new ApiError(response.status, await response.json())
    }

    return response.json()
  }
}

// 使用
const apiClient = new ApiClient()
const sessions = await apiClient.get<ChatSession[]>('/api/sessions')
```

