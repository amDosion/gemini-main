# Kiro Powers - Gemini Fullstack 环境变量配置

# 本文件包含 MCP 服务器所需的环境变量配置
# 复制此文件为 .env 并填入实际的 API 密钥

# ==================== Context7 ====================
# Context7 API 密钥（用于读取外部库文档）
# 获取地址：https://context7.com
CONTEXT7_API_KEY=your_context7_api_key_here

# ==================== GitHub ====================
# GitHub Personal Access Token（用于 GitHub 操作）
# 获取地址：https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_token_here

# ==================== Gemini ====================
# Google Gemini API 密钥（用于 Gemini MCP 服务器）
# 获取地址：https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ==================== OpenAI (Codex) ====================
# OpenAI API 密钥（用于 Codex MCP 工具包）
# 如果使用第三方 API，填入对应的密钥
OPENAI_API_KEY_CODEX=your_openai_codex_key_here
OPENAI_BASE_URL=https://yourapi.cn/v1

# ==================== OpenAI (Claude Code) ====================
# OpenAI API 密钥（用于 Claude Code MCP 服务器）
# 如果使用第三方 API，填入对应的密钥
OPENAI_API_KEY_CLAUDE=your_openai_claude_key_here

# ==================== Upstash Redis ====================
# Upstash Redis REST URL 和 Token（用于缓存）
# 获取地址：https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=your_redis_url_here
UPSTASH_REDIS_REST_TOKEN=your_redis_token_here

# ==================== PostgreSQL ====================
# PostgreSQL 数据库连接 URL（用于 Postgres MCP）
# 格式：postgresql://user:password@host:port/database
DATABASE_URL=your_database_url_here

# ==================== 安全提示 ====================
# 1. 永远不要将 .env 文件提交到 Git 仓库
# 2. 确保 .env 文件在 .gitignore 中
# 3. 定期旋转 API 密钥
# 4. 使用最小权限原则配置 API 密钥
# 5. 不要在代码中硬编码 API 密钥

# ==================== 可选配置 ====================
# 如果某些 MCP 服务器不需要，可以在 mcp.json 中设置 disabled: true
