{
  "enabled": false,
  "name": "create-test-file",
  "description": "Automatically create corresponding test file for new source files",
  "when": {
    "type": "fileCreated",
    "patterns": [
      "{backend/**/*.py,frontend/**/*.{ts,tsx}}"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A new source file has been created at ${FILE}. Please use Desktop Commander MCP to create a corresponding test file:\n\nFor Python files (backend/**/*.py):\n- Create test file at same location with 'test_' prefix\n- Example: backend/app/services/auth.py → backend/app/services/test_auth.py\n- Use pytest framework\n- Import the module being tested\n- Add placeholder test functions\n\nFor TypeScript files (frontend/**/*.{ts,tsx}):\n- Create test file with '.test.ts' or '.test.tsx' suffix\n- Example: frontend/components/Button.tsx → frontend/components/Button.test.tsx\n- Use Jest/React Testing Library\n- Import the component/function being tested\n- Add placeholder test cases\n\nUse mcp_desktop_commander_mcp_write_file() to create the test file. Only create if the source file is not already a test file."
  },
  "blocking": false
}