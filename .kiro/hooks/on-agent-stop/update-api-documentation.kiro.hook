{
  "enabled": false,
  "version": "1",
  "name": "update-api-documentation",
  "description": "Regenerate API documentation",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "cd backend && python -m app.main --generate-openapi-spec > openapi.json"
  }
}