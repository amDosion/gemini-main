{
  "enabled": true,
  "version": "1",
  "name": "validate-api-schema",
  "description": "Validate OpenAPI schema consistency",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "cd backend && python -c 'from app.main import app; print(\"API schema valid\")'"
  }
}