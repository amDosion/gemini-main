{
  "enabled": true,
  "name": "check-file-size-limit",
  "description": "检查文件大小是否符合模块化原则（后端 < 300 行，前端 < 200 行）",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "{backend/**/*.py,frontend/**/*.{ts,tsx}}"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "python .claude/scripts/check_file_size.py ${FILE}"
  },
  "blocking": false
}