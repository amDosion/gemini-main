{
  "enabled": true,
  "name": "lint-python",
  "description": "Lint Python files using Ruff",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "backend/**/*.py"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "cd backend && ruff check ${FILE} --fix"
  },
  "blocking": false
}