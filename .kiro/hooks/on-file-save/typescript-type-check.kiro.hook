{
  "enabled": true,
  "name": "typescript-type-check",
  "description": "Type check TypeScript files",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "frontend/**/*.{ts,tsx}"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npx tsc --noEmit --skipLibCheck ${FILE}"
  },
  "blocking": false
}