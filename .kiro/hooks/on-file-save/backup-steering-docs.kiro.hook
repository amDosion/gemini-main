{
  "enabled": true,
  "name": "backup-steering-docs",
  "description": "编辑 Steering 文档前自动备份",
  "when": {
    "type": "fileEdited",
    "patterns": [
      ".kiro/steering/**/*.md"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "cp ${FILE} ${FILE}.backup.$(date +%Y%m%d_%H%M%S)"
  },
  "blocking": false
}