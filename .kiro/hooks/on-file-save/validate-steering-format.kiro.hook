{
  "enabled": true,
  "name": "validate-steering-format",
  "description": "验证 Steering 文档格式",
  "when": {
    "type": "fileEdited",
    "patterns": [
      ".kiro/docs/**/*.md"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "python .claude/scripts/validate_steering_format.py ${FILE}"
  },
  "blocking": false
}