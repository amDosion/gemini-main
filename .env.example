# =============================================================================
# Gemini Full-Stack Development - 环境变量配置示例
# =============================================================================
#
# 使用说明：
# 1. 复制此文件为 .env 或 .env.local
# 2. 填入你的实际 API 密钥
# 3. 确保 .env 文件已添加到 .gitignore 中
#
# ⚠️  警告：永远不要将包含真实 API 密钥的 .env 文件提交到 Git！
#
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI API (用于 Codex MCP Toolkit)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# -----------------------------------------------------------------------------
# Claude Code MCP (如果需要单独配置)
# -----------------------------------------------------------------------------
OPENAI_API_KEY_CLAUDE=your_claude_api_key_here
OPENAI_BASE_URL_CLAUDE=https://yourapi.cn/v1

# -----------------------------------------------------------------------------
# Google Gemini API
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# GitHub (可选 - 用于 GitHub MCP Server)
# -----------------------------------------------------------------------------
# GITHUB_PERSONAL_ACCESS_TOKEN=your_github_token_here

# -----------------------------------------------------------------------------
# PostgreSQL (可选 - 用于 Postgres MCP Server)
# -----------------------------------------------------------------------------
# POSTGRES_CONNECTION_STRING=postgresql://user:password@localhost:5432/dbname

# -----------------------------------------------------------------------------
# Redis (可选 - 用于 Redis MCP Server)
# -----------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Qwen-Image-Layered 图层分解服务（外部独立部署）
# -----------------------------------------------------------------------------
# 服务端点（域名:端口/路径）
# QWEN_LAYERED_ENDPOINT=http://192.168.1.100:7860/decompose

# 外部服务独立认证密钥（非项目内 JWT）
# QWEN_LAYERED_API_KEY=your_qwen_layered_api_key_here

# 超时时间（秒，默认 180）
# QWEN_LAYERED_TIMEOUT_SEC=180

# =============================================================================
# 获取 API 密钥的链接
# =============================================================================
#
# OpenAI API: https://platform.openai.com/api-keys
# Google Gemini: https://makersuite.google.com/app/apikey
# GitHub Token: https://github.com/settings/tokens
#
# =============================================================================
